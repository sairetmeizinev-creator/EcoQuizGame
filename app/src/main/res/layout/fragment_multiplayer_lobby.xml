<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_vibrant"
    android:padding="24dp">

    <!-- Cartoon Decorations -->
    <ImageView
        android:id="@+id/multiplayerIcon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="64dp"
        android:src="@android:drawable/ic_menu_share"
        app:tint="@color/accent_blue"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="@null" />

    <ImageView
        android:id="@+id/lobbyLeaf1"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_leaf"
        android:alpha="0.3"
        app:tint="@color/primary_green"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="-20dp"
        android:layout_marginBottom="40dp"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/lobbyTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/multiplayer_mode"
        android:textColor="@color/primary_green_dark"
        android:textSize="32sp"
        android:fontFamily="sans-serif-black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/multiplayerIcon" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/codeLayout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:hint="@string/game_code"
        app:boxStrokeColor="@color/accent_blue"
        app:hintTextColor="@color/accent_blue"
        app:layout_constraintTop_toBottomOf="@id/lobbyTitle">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/codeInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:inputType="textCapCharacters" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/generateCodeButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="24dp"
        android:text="@string/generate_code"
        android:textSize="18sp"
        android:fontFamily="sans-serif-bold"
        app:cornerRadius="16dp"
        app:backgroundTint="@color/accent_blue"
        app:layout_constraintTop_toBottomOf="@id/codeLayout" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/joinButton"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="12dp"
        android:text="@string/join_game"
        android:textSize="18sp"
        android:fontFamily="sans-serif-bold"
        app:cornerRadius="16dp"
        android:textColor="@color/accent_blue"
        app:strokeColor="@color/accent_blue"
        app:layout_constraintTop_toBottomOf="@id/generateCodeButton" />

</androidx.constraintlayout.widget.ConstraintLayout>